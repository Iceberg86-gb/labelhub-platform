{
  "name": "@labelhub/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm gen:api && vite",
    "build": "pnpm gen:api && tsc -p tsconfig.json && vite build",
    "typecheck": "pnpm gen:api && tsc -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "bench": "vitest bench --run --config vitest.config.ts",
    "gen:api": "openapi-typescript ../../packages/contracts/openapi/labelhub.yaml -o src/shared/api/generated/schema.d.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@douyinfe/semi-icons": "^2.85.0",
    "@douyinfe/semi-ui": "^2.85.0",
    "@formily/core": "^2.3.2",
    "@formily/react": "^2.3.2",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-virtual": "^3",
    "dompurify": "^3.4.8",
    "openapi-fetch": "^0.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.4.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2"
  }
}
