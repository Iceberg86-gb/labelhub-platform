# Copy to .env.prod, edit every CHANGE_ME value, then run: chmod 600 .env.prod
# Losing LABELHUB_LLM_PROVIDER_MASTER_KEY makes stored provider secrets undecryptable.

# MySQL database name used by api and backup scripts.
MYSQL_DATABASE=CHANGE_ME_DATABASE_NAME
# MySQL application user.
MYSQL_USER=CHANGE_ME_DATABASE_USER
# MySQL application password.
MYSQL_PASSWORD=CHANGE_ME_MYSQL_PASSWORD
# MySQL root password for emergency maintenance.
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD
# JDBC URL used by the API container, for example jdbc:mysql://mysql:3306/labelhub.
DATABASE_URL=CHANGE_ME_DATABASE_URL

# HS256 JWT secret, generate with openssl rand -base64 32.
JWT_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
# Access token lifetime in hours.
JWT_TTL_HOURS=CHANGE_ME_JWT_TTL_HOURS
# Refresh token lifetime in days.
REFRESH_TTL_DAYS=CHANGE_ME_REFRESH_TTL_DAYS
# Initial platform admin password, at least 12 characters.
LABELHUB_PA_INITIAL_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_12_PLUS
# Shared internal token between api and agent.
LABELHUB_INTERNAL_TOKEN=CHANGE_ME_INTERNAL_TOKEN
# Master key for encrypting LLM provider secrets; do not rotate casually.
LABELHUB_LLM_PROVIDER_MASTER_KEY=CHANGE_ME_MASTER_KEY

# API port inside the container.
LABELHUB_API_PORT=CHANGE_ME_API_PORT
# Agent port inside the container.
LABELHUB_AGENT_PORT=CHANGE_ME_AGENT_PORT
# Agent callback base URL for the API service.
LABELHUB_API_BASE_URL=CHANGE_ME_API_BASE_URL

# Active API-side AI provider.
LABELHUB_AI_PROVIDER=CHANGE_ME_AI_PROVIDER
# OpenAI-compatible provider base URL.
AI_BASE_URL=CHANGE_ME_AI_BASE_URL
# OpenAI-compatible provider API key.
AI_API_KEY=CHANGE_ME_AI_API_KEY
# OpenAI-compatible model name.
AI_MODEL_NAME=CHANGE_ME_AI_MODEL_NAME
# Display name for the OpenAI-compatible provider.
AI_PROVIDER_NAME=CHANGE_ME_AI_PROVIDER_NAME
# Estimated cost per AI call fallback.
AI_COST_PER_CALL=CHANGE_ME_AI_COST_PER_CALL
# Provider timeout, for example 30s.
AI_TIMEOUT=CHANGE_ME_AI_TIMEOUT
# Provider retry attempts.
AI_MAX_ATTEMPTS=CHANGE_ME_AI_MAX_ATTEMPTS
# Provider retry base delay, for example 1000ms.
AI_BASE_DELAY=CHANGE_ME_AI_BASE_DELAY

# Object storage endpoint; use http://minio:9000 for bundled MinIO.
OBJECT_STORAGE_ENDPOINT=CHANGE_ME_OBJECT_STORAGE_ENDPOINT
# Object storage region.
OBJECT_STORAGE_REGION=CHANGE_ME_OBJECT_STORAGE_REGION
# Object storage access key; also seeds bundled MinIO root user.
OBJECT_STORAGE_ACCESS_KEY=CHANGE_ME_OBJECT_STORAGE_ACCESS_KEY
# Object storage secret key; also seeds bundled MinIO root password.
OBJECT_STORAGE_SECRET_KEY=CHANGE_ME_OBJECT_STORAGE_SECRET_KEY
# Object storage bucket created by minio-init.
OBJECT_STORAGE_BUCKET=CHANGE_ME_OBJECT_STORAGE_BUCKET
# Path-style S3 access flag; true for MinIO.
OBJECT_STORAGE_PATH_STYLE=CHANGE_ME_OBJECT_STORAGE_PATH_STYLE

# Agent worker identity.
LABELHUB_AGENT_WORKER_ID=CHANGE_ME_AGENT_WORKER_ID
# Agent outbox poll delay in milliseconds.
LABELHUB_AGENT_OUTBOX_POLL_DELAY_MS=CHANGE_ME_OUTBOX_POLL_DELAY_MS
# Agent outbox batch size.
LABELHUB_AGENT_OUTBOX_BATCH_SIZE=CHANGE_ME_OUTBOX_BATCH_SIZE
# Agent outbox max attempts.
LABELHUB_AGENT_OUTBOX_MAX_ATTEMPTS=CHANGE_ME_OUTBOX_MAX_ATTEMPTS
# Agent outbox retry base delay in milliseconds.
LABELHUB_AGENT_OUTBOX_BASE_DELAY_MS=CHANGE_ME_OUTBOX_BASE_DELAY_MS
# Agent outbox lease seconds.
LABELHUB_AGENT_OUTBOX_LEASE_SECONDS=CHANGE_ME_OUTBOX_LEASE_SECONDS

# Agent primary runtime provider.
LLM_PRIMARY_PROVIDER=CHANGE_ME_LLM_PRIMARY_PROVIDER
# Doubao endpoint when using doubao.
DOUBAO_ENDPOINT=CHANGE_ME_DOUBAO_ENDPOINT
# Doubao API key when using doubao.
DOUBAO_API_KEY=CHANGE_ME_DOUBAO_API_KEY
# Doubao model when using doubao.
DOUBAO_MODEL=CHANGE_ME_DOUBAO_MODEL
# OpenAI endpoint when using openai.
OPENAI_ENDPOINT=CHANGE_ME_OPENAI_ENDPOINT
# OpenAI API key when using openai.
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
# OpenAI model when using openai.
OPENAI_MODEL=CHANGE_ME_OPENAI_MODEL

# API JVM options.
API_JAVA_OPTS=CHANGE_ME_API_JAVA_OPTS
# Agent JVM options.
AGENT_JAVA_OPTS=CHANGE_ME_AGENT_JAVA_OPTS
