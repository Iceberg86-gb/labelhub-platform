# Application
JWT_SECRET=dev-only-32-bytes-minimum-secret-please-change-me
LABELHUB_API_PORT=8080
LABELHUB_AGENT_PORT=8081
LABELHUB_API_BASE_URL=http://localhost:8080
LABELHUB_INTERNAL_TOKEN=dev-internal-token

# Web
VITE_API_BASE_URL=http://localhost:8080
LABELHUB_API_PROXY_TARGET=http://localhost:8080

# MySQL
MYSQL_DATABASE=labelhub
MYSQL_USER=labelhub
MYSQL_PASSWORD=labelhub
MYSQL_ROOT_PASSWORD=labelhub-root
DATABASE_URL=jdbc:mysql://localhost:3306/labelhub?useUnicode=true&characterEncoding=utf8&serverTimezone=UTC

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Object storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=labelhub-files
S3_ACCESS_KEY=labelhub
S3_SECRET_KEY=labelhub-secret

# LLM
DOUBAO_ENDPOINT=replace-with-doubao-endpoint
DOUBAO_API_KEY=replace-with-doubao-api-key
DOUBAO_MODEL=doubao-pro
LLM_PRIMARY_PROVIDER=doubao
OPENAI_API_KEY=replace-with-openai-fallback-key
OPENAI_MODEL=gpt-4.1-mini
