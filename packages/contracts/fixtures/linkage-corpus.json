        { "field": "score", "op": "gt", "value": 5 }
      ] } },
      { "stableId": "any_target", "label": "Any Target", "type": "text", "requiredWhen": { "anyOf": [
        { "field": "type", "op": "eq", "value": "manual" },
        { "field": "score", "op": "lt", "value": 5 }
      ] } }
    ] },
    "payload": { "type": "other", "score": 6 },
    "expectedErrors": [{ "stableId": "all_target", "reason": "此字段必填" }],
    "expectedPublishErrors": [],
    "expectSymmetry": true
  },
